{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ESLint not configured'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:push": "prisma db push --schema=prisma/schema",
    "db:studio": "prisma studio --schema=prisma/schema",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate --schema=prisma/schema"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@shashvat/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
